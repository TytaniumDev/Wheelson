<Ui xmlns="http://www.blizzard.com/wow/ui/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/ https://raw.githubusercontent.com/AcidWeb/wow-ui-source/main/Interface/FrameXML/UI.xsd">

    <!-- Main Window Frame -->
    <Frame name="WHLSNMainFrame" parent="UIParent" hidden="true"
           enableMouse="true" movable="true" toplevel="true"
           frameStrata="DIALOG" clampedToScreen="true">
        <Size x="600" y="500"/>
        <Anchors>
            <Anchor point="CENTER"/>
        </Anchors>

        <Scripts>
            <OnMouseDown>
                self:StartMoving()
            </OnMouseDown>
            <OnMouseUp>
                self:StopMovingOrSizing()
            </OnMouseUp>
            <OnDragStart>
                self:StartMoving()
            </OnDragStart>
            <OnDragStop>
                self:StopMovingOrSizing()
            </OnDragStop>
        </Scripts>

        <Layers>
            <!-- Background -->
            <Layer level="BACKGROUND">
                <Texture setAllPoints="true">
                    <Color r="0.05" g="0.05" b="0.08" a="0.95"/>
                </Texture>
            </Layer>
            <!-- Border -->
            <Layer level="BORDER">
                <Texture name="$parentBorderTop">
                    <Size y="2"/>
                    <Anchors>
                        <Anchor point="TOPLEFT"/>
                        <Anchor point="TOPRIGHT"/>
                    </Anchors>
                    <Color r="0.6" g="0.5" b="0.3" a="1"/>
                </Texture>
                <Texture name="$parentBorderBottom">
                    <Size y="2"/>
                    <Anchors>
                        <Anchor point="BOTTOMLEFT"/>
                        <Anchor point="BOTTOMRIGHT"/>
                    </Anchors>
                    <Color r="0.6" g="0.5" b="0.3" a="1"/>
                </Texture>
                <Texture name="$parentBorderLeft">
                    <Size x="2"/>
                    <Anchors>
                        <Anchor point="TOPLEFT"/>
                        <Anchor point="BOTTOMLEFT"/>
                    </Anchors>
                    <Color r="0.6" g="0.5" b="0.3" a="1"/>
                </Texture>
                <Texture name="$parentBorderRight">
                    <Size x="2"/>
                    <Anchors>
                        <Anchor point="TOPRIGHT"/>
                        <Anchor point="BOTTOMRIGHT"/>
                    </Anchors>
                    <Color r="0.6" g="0.5" b="0.3" a="1"/>
                </Texture>
            </Layer>
            <!-- Title -->
            <Layer level="OVERLAY">
                <FontString name="$parentTitle" inherits="GameFontNormalLarge"
                            text="Wheelson">
                    <Anchors>
                        <Anchor point="TOP" y="-12"/>
                    </Anchors>
                    <Color r="1" g="0.82" b="0"/>
                </FontString>
            </Layer>
        </Layers>

        <Frames>
            <!-- Close Button -->
            <Button name="$parentCloseButton" inherits="UIPanelCloseButton">
                <Anchors>
                    <Anchor point="TOPRIGHT" x="-4" y="-4"/>
                </Anchors>
            </Button>

            <!-- Content Container (views swap inside here) -->
            <Frame name="$parentContent">
                <Anchors>
                    <Anchor point="TOPLEFT" x="16" y="-40"/>
                    <Anchor point="BOTTOMRIGHT" x="-16" y="16"/>
                </Anchors>
            </Frame>
        </Frames>
    </Frame>

</Ui>
